---
// CMSの設定をPKCEフローで直接定義します。
// これにより、Netlifyへの不要な通信を完全に遮断し、GitHub認証を確実に行います。
const config = {
  backend: {
    name: "github",
    repo: "siegenom/siegenom.github.io", // あなたのリポジトリ
    branch: "main",                       // メインブランチ
    auth_type: "pkce", // ★★★ 認証方式を 'implicit' から 'pkce' に変更 ★★★
    app_id: "Ov23liaITErivL1rF7bJ", // あなたのGitHub OAuth AppのClient ID
  },
  media_folder: "public/images/blog",
  public_folder: "/images/blog",
  collections: [
    {
      name: "blog",
      label: "ブログ記事",
      folder: "src/content/blog",
      create: true,
      slug: "{{year}}-{{month}}-{{day}}-{{slug}}",
      fields: [
        { label: "タイトル", name: "title", widget: "string" },
        { label: "説明", name: "description", widget: "string" },
        { label: "投稿日", name: "pubDate", widget: "datetime" },
        { label: "更新日", name: "updatedDate", widget: "datetime", required: false },
        { label: "ヒーロー画像", name: "heroImage", widget: "image", required: false },
        { label: "記事内容", name: "body", widget: "markdown" },
      ],
    },
  ],
};
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Manager</title>
  <!-- Netlify CMSのコアスクリプトを読み込みます -->
  <script src="https://unpkg.com/netlify-cms@^2.0.0/dist/netlify-cms.js"></script>
</head>
<body>
  <!--
    Astroの 'define:vars' を使用して、サーバーサイドで定義した 'config' オブジェクトを
    クライアントサイドのJavaScriptに安全に渡し、CMSを初期化します。
  -->
  <script define:vars={{ config }}>
    CMS.init({ config });
  </script>
</body>
</html>
