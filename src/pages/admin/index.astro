---
// Astro Component
---
<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Manager</title>
  <style>
    /* デバッグ表示用のスタイル */
    #debug-panel { position: fixed; top: 10px; left: 10px; background: #222; color: white; padding: 15px; border: 1px solid #555; border-radius: 5px; font-family: monospace; font-size: 14px; z-index: 9999; max-width: 90%; }
    .debug-log { margin-bottom: 5px; }
    .debug-success { color: #76ff03; }
    .debug-error { color: #ff5252; }
    .debug-info { color: #40c4ff; }
  </style>
  
  <script defer src="https://unpkg.com/netlify-cms@^2.0.0/dist/netlify-cms.js"></script>
</head>
<body>
  <div id="nc-root"></div>

  <script is:inline>
    // デバッグログを画面に表示するパネルを作成
    const panel = document.createElement('div');
    panel.id = 'debug-panel';
    document.body.appendChild(panel);

    function log(message, type = 'info') {
      const p = document.createElement('p');
      p.className = `debug-log debug-${type}`;
      p.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
      panel.appendChild(p);
      console.log(message);
    }

    log('デバッグスクリプト初期化完了');

    // DOMの準備ができた時点でチェックを開始
    document.addEventListener('DOMContentLoaded', () => {
      log('DOMContentLoadedイベント発生: DOM準備完了');

      // 1. nc-rootの存在チェック
      if (document.getElementById('nc-root')) {
        log('✅ [OK] <div id="nc-root"></div> が存在します。', 'success');
      } else {
        log('❌ [NG] <div id="nc-root"></div> が見つかりません！', 'error');
      }

      // 2. config.ymlのフェッチ試行
      log('config.yml の読み込みを試行します...');
      fetch('/admin/config.yml')
        .then(response => {
          log(`config.yml のレスポンスステータス: ${response.status}`);
          if (response.ok) {
            log('✅ [OK] /admin/config.yml の読み込みに成功しました。', 'success');
            log('🎉 全てのチェックが完了しました。Netlify CMSが起動します。');
            // 成功したら3秒後にデバッグパネルを消す
            setTimeout(() => { panel.style.display = 'none'; }, 3000);
          } else {
            log(`❌ [NG] /admin/config.yml の読み込みに失敗しました (HTTP ${response.status})。`, 'error');
            log('解決策: config.ymlが "public/admin/" ディレクトリに正しく配置されているか確認してください。', 'info');
          }
        })
        .catch(err => {
          log(`❌ [NG] config.yml の読み込み中にネットワークエラーが発生しました: ${err}`, 'error');
        });
    });
  </script>
</body>
</html>